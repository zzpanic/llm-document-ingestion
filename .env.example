# LLM Document Ingestion Service Configuration
# Copy this file to .env and update values as needed for your environment

# === LLM Provider Configuration ===

# Endpoint for LM Studio server
# Local development (non-Docker): http://localhost:1234
# Docker Desktop (Mac/Windows): http://host.docker.internal:1234
# Docker on Linux / remote server: use the host's LAN IP, e.g. http://192.168.1.81:1234
# Must be a valid HTTP/HTTPS URL
LM_STUDIO_ENDPOINT=http://localhost:1234

# Model identifier to use for extraction
# Common options: qwen3.5-9b, qwen-vl-plus, llava, llava-1.5
# Must match a model available in LM Studio
LITELM_API_MODEL=qwen3.5-9b

# === Application Settings ===

# Maximum number of images to process per batch
# Must be >= 1, recommended 20-100
MAX_IMAGES_PER_BATCH=100

# Maximum image file size in MB
# Must be >= 1, typical range 5-50MB
MAX_IMAGE_SIZE_MB=10

# === Optional: Cloud API Keys ===
# Only needed if using cloud providers instead of local LM Studio

# OpenAI API key for GPT-4 Vision
# OPENAI_API_KEY=sk-...

# Anthropic API key for Claude
# ANTHROPIC_API_KEY=sk-ant-...

# === Development Settings ===

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
# LOG_LEVEL=INFO

# === Notes ===
# - LM_STUDIO_ENDPOINT must be accessible from the application
# - LITELM_API_MODEL should have vision capabilities
# - Configuration is validated on startup
# - Invalid values will cause the application to fail to start